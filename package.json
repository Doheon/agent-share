{
  "name": "@doheon/ash",
  "version": "0.1.3",
  "description": "Distributed P2P AI coding agent network — share idle compute, earn credits, fully self-hosted.",
  "keywords": [
    "ai",
    "agent",
    "p2p",
    "cli",
    "claude",
    "codex",
    "hyperswarm"
  ],
  "license": "MIT",
  "author": "Doheon",
  "repository": {
    "type": "git",
    "url": "https://github.com/Doheon/agent-share.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "bin": {
    "ash": "bin/ash"
  },
  "files": [
    "bin",
    "cli",
    "core",
    "shared",
    "tsconfig.json",
    "README.md",
    "README.ko.md",
    "SECURITY.md",
    "LICENSE",
    "!**/*_test.ts",
    "!**/*.test.ts",
    "!**/__tests__/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node --import tsx/esm cli/main.ts",
    "build": "npm pack",
    "test": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7",
    "commander": "^12",
    "corestore": "^7.9.2",
    "hypercore": "^11.28.1",
    "hyperswarm": "^4.17.0",
    "ink": "^7.0.1",
    "react": "^19",
    "string-width": "^8",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@hyperswarm/testnet": "^3.1.4",
    "@types/node": "^22",
    "@types/react": "^19",
    "vitest": "4.1.4"
  }
}
